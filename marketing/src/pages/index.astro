---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Self-Hosted Envelope Budgeting">
  <!-- Nav -->
  <nav
    class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-lg border-b border-gray-200/60"
  >
    <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <div
          class="w-7 h-7 bg-gray-900 rounded-lg flex items-center justify-center"
        >
          <svg
            class="w-4 h-4 text-white"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"
            ></path>
          </svg>
        </div>
        <span class="font-serif font-bold text-gray-900">Envelopes</span>
      </a>
      <div class="flex items-center gap-5">
        <a
          href="#features"
          class="text-sm text-gray-500 hover:text-gray-900 transition-colors"
          >Features</a
        >
        <a
          href="#how-it-works"
          class="text-sm text-gray-500 hover:text-gray-900 transition-colors"
          >How It Works</a
        >
        <a
          href="#install"
          class="text-sm text-gray-500 hover:text-gray-900 transition-colors"
          >Install</a
        >
        <a
          href="https://github.com/kevin-wynn/envelopes"
          target="_blank"
          class="text-sm text-gray-500 hover:text-gray-900 transition-colors flex items-center gap-1.5"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
            ><path
              d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
            ></path></svg
          >
          GitHub
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="pt-28 pb-0 px-6 overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-10">
        <div
          class="inline-flex items-center gap-2 bg-brand-50 border border-brand-200 text-brand-700 px-3.5 py-1 rounded-full text-xs font-semibold mb-6 tracking-wide"
        >
          <svg
            class="w-3.5 h-3.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"
            ></path></svg
          >
          SELF-HOSTED &middot; OPEN SOURCE &middot; FREE FOREVER
        </div>
        <h1
          class="font-serif text-5xl md:text-6xl font-bold text-gray-900 tracking-tight leading-[1.1] mb-5"
        >
          Budgeting that<br />lives on <span class="text-brand-600"
            >your server</span
          >
        </h1>
        <p class="text-lg text-gray-500 leading-relaxed max-w-xl mx-auto mb-8">
          Envelope budgeting inspired by YNAB and Monarch — self-hosted, no
          subscriptions, no data sharing.
        </p>
        <div class="flex items-center justify-center gap-3">
          <a
            href="#install"
            class="inline-flex items-center gap-2 bg-gray-900 hover:bg-gray-800 text-white px-6 py-2.5 rounded-lg font-semibold text-sm transition-colors shadow-sm"
          >
            Get Started Free
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3"></path>
            </svg>
          </a>
          <a
            href="https://github.com/kevin-wynn/envelopes"
            target="_blank"
            class="inline-flex items-center gap-2 bg-gray-100 hover:bg-gray-200 text-gray-700 px-6 py-2.5 rounded-lg font-semibold text-sm transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path></svg
            >
            View Source
          </a>
        </div>
      </div>

      <!-- App Mockup — browser chrome with full dashboard -->
      <div class="relative mx-auto max-w-5xl">
        <!-- glow -->
        <div
          class="absolute -inset-4 bg-gradient-to-b from-brand-300/20 via-brand-100/10 to-transparent rounded-3xl blur-3xl pointer-events-none"
        >
        </div>

        <div
          class="relative rounded-xl border border-gray-800 shadow-[0_30px_80px_-10px_rgba(0,0,0,0.5)] overflow-hidden"
        >
          <!-- Title bar -->
          <div
            class="flex items-center gap-3 px-4 py-3 bg-gray-900 border-b border-gray-800"
          >
            <div class="flex gap-1.5 shrink-0">
              <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
              <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
              <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
            </div>
            <div class="flex-1 flex justify-center">
              <div
                class="bg-gray-800 rounded-md px-4 py-1 text-xs text-gray-400 font-mono flex items-center gap-1.5"
              >
                <svg
                  class="w-3 h-3 text-green-400"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"
                  ></path></svg
                >
                localhost:4321/app/dashboard
              </div>
            </div>
          </div>

          <!-- App shell -->
          <div class="flex bg-[#F8FAFC]" style="min-height: 480px">
            <!-- Sidebar -->
            <div class="w-52 bg-[#0F172A] shrink-0 flex flex-col p-4">
              <div class="flex items-center gap-2.5 mb-8">
                <div
                  class="w-7 h-7 bg-[#22C55E] rounded-lg flex items-center justify-center shrink-0"
                >
                  <svg
                    class="w-4 h-4 text-white"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"
                    ></path>
                  </svg>
                </div>
                <span class="text-sm font-serif font-bold text-slate-100"
                  >Envelopes</span
                >
              </div>
              <nav class="space-y-0.5 flex-1">
                <div
                  class="flex items-center gap-2.5 bg-[#253347] rounded-lg px-3 py-2"
                >
                  <svg
                    class="w-4 h-4 text-green-400 shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.75"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"
                    ></path></svg
                  >
                  <span class="text-xs font-semibold text-slate-100"
                    >Dashboard</span
                  >
                </div>
                <div class="flex items-center gap-2.5 rounded-lg px-3 py-2">
                  <svg
                    class="w-4 h-4 text-slate-500 shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.75"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M21 12a2.25 2.25 0 00-2.25-2.25H15a3 3 0 11-6 0H5.25A2.25 2.25 0 003 12m18 0v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 013 9m18 0V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 013 6v3"
                    ></path></svg
                  >
                  <span class="text-xs text-slate-500">Budget</span>
                </div>
                <div class="flex items-center gap-2.5 rounded-lg px-3 py-2">
                  <svg
                    class="w-4 h-4 text-slate-500 shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.75"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z"
                    ></path></svg
                  >
                  <span class="text-xs text-slate-500">Accounts</span>
                </div>
                <div class="flex items-center gap-2.5 rounded-lg px-3 py-2">
                  <svg
                    class="w-4 h-4 text-slate-500 shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.75"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"
                    ></path></svg
                  >
                  <span class="text-xs text-slate-500">Transactions</span>
                </div>
                <div class="flex items-center gap-2.5 rounded-lg px-3 py-2">
                  <svg
                    class="w-4 h-4 text-slate-500 shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.75"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"
                    ></path></svg
                  >
                  <span class="text-xs text-slate-500">Reports</span>
                </div>
                <div class="flex items-center gap-2.5 rounded-lg px-3 py-2">
                  <svg
                    class="w-4 h-4 text-slate-500 shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.75"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"
                    ></path></svg
                  >
                  <span class="text-xs text-slate-500">Goals</span>
                </div>
              </nav>
              <!-- Balance pill at bottom -->
              <div class="mt-4 bg-[#1E293B] rounded-lg p-3">
                <p class="text-[10px] text-slate-400 mb-1">Ready to Assign</p>
                <p class="text-sm font-bold text-emerald-400">$3,420.00</p>
              </div>
            </div>

            <!-- Main content -->
            <div class="flex-1 p-5 overflow-hidden">
              <div class="flex items-center justify-between mb-5">
                <div>
                  <h1 class="text-sm font-bold text-gray-800">Dashboard</h1>
                  <p class="text-[10px] text-gray-400">December 2024</p>
                </div>
                <div
                  class="bg-white border border-gray-200 rounded-lg px-3 py-1.5 text-[10px] text-gray-500 font-medium"
                >
                  + Add Transaction
                </div>
              </div>

              <!-- Stat cards -->
              <div class="grid grid-cols-4 gap-2.5 mb-4">
                <div
                  class="bg-white rounded-xl p-3 shadow-sm border border-gray-100"
                >
                  <p
                    class="text-[9px] text-gray-400 font-medium uppercase tracking-wide mb-1.5"
                  >
                    Net Worth
                  </p>
                  <p class="text-base font-bold text-gray-900">$24,830</p>
                  <p
                    class="text-[9px] text-emerald-500 mt-0.5 flex items-center gap-0.5"
                  >
                    <svg
                      class="w-2.5 h-2.5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2.5"
                      ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"
                      ></path></svg
                    >
                    +$840 this month
                  </p>
                </div>
                <div
                  class="bg-white rounded-xl p-3 shadow-sm border border-gray-100"
                >
                  <p
                    class="text-[9px] text-gray-400 font-medium uppercase tracking-wide mb-1.5"
                  >
                    Total Assets
                  </p>
                  <p class="text-base font-bold text-gray-900">$31,420</p>
                  <p
                    class="text-[9px] text-emerald-500 mt-0.5 flex items-center gap-0.5"
                  >
                    <svg
                      class="w-2.5 h-2.5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2.5"
                      ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"
                      ></path></svg
                    >
                    +$1,200 this month
                  </p>
                </div>
                <div
                  class="bg-white rounded-xl p-3 shadow-sm border border-gray-100"
                >
                  <p
                    class="text-[9px] text-gray-400 font-medium uppercase tracking-wide mb-1.5"
                  >
                    Liabilities
                  </p>
                  <p class="text-base font-bold text-red-500">$6,590</p>
                  <p
                    class="text-[9px] text-emerald-500 mt-0.5 flex items-center gap-0.5"
                  >
                    <svg
                      class="w-2.5 h-2.5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2.5"
                      ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M2.25 6L9 12.75l4.306-4.307a11.95 11.95 0 015.814 5.519l2.74 1.22m0 0l-5.94 2.28m5.94-2.28l-2.28-5.941"
                      ></path></svg
                    >
                    -$360 paid off
                  </p>
                </div>
                <div
                  class="bg-white rounded-xl p-3 shadow-sm border border-gray-100"
                >
                  <p
                    class="text-[9px] text-gray-400 font-medium uppercase tracking-wide mb-1.5"
                  >
                    Saved This Month
                  </p>
                  <p class="text-base font-bold text-gray-900">$1,240</p>
                  <p class="text-[9px] text-gray-400 mt-0.5">of $1,500 goal</p>
                  <!-- mini progress bar -->
                  <div
                    class="mt-1.5 h-1 bg-gray-100 rounded-full overflow-hidden"
                  >
                    <div
                      class="h-full bg-emerald-400 rounded-full"
                      style="width:82%"
                    >
                    </div>
                  </div>
                </div>
              </div>

              <!-- Charts row -->
              <div class="grid grid-cols-5 gap-2.5 mb-2.5">
                <!-- Donut chart — col-span-2 -->
                <div
                  class="col-span-2 bg-white rounded-xl p-4 shadow-sm border border-gray-100"
                >
                  <p class="text-[10px] font-semibold text-gray-700 mb-3">
                    Spending by Category
                  </p>
                  <div class="flex items-center gap-3">
                    <svg
                      viewBox="0 0 120 120"
                      width="90"
                      height="90"
                      class="shrink-0"
                    >
                      <!-- background track -->
                      <circle
                        cx="60"
                        cy="60"
                        r="45"
                        fill="none"
                        stroke="#f3f4f6"
                        stroke-width="22"></circle>
                      <!-- Housing 30% -->
                      <circle
                        cx="60"
                        cy="60"
                        r="45"
                        fill="none"
                        stroke="#16A34A"
                        stroke-width="22"
                        stroke-dasharray="84.8 197.9"
                        stroke-dashoffset="0"
                        transform="rotate(-90 60 60)"></circle>
                      <!-- Groceries 20% -->
                      <circle
                        cx="60"
                        cy="60"
                        r="45"
                        fill="none"
                        stroke="#0EA5E9"
                        stroke-width="22"
                        stroke-dasharray="56.5 226.2"
                        stroke-dashoffset="-84.8"
                        transform="rotate(-90 60 60)"></circle>
                      <!-- Transport 16% -->
                      <circle
                        cx="60"
                        cy="60"
                        r="45"
                        fill="none"
                        stroke="#F59E0B"
                        stroke-width="22"
                        stroke-dasharray="45.2 237.5"
                        stroke-dashoffset="-141.3"
                        transform="rotate(-90 60 60)"></circle>
                      <!-- Dining 12% -->
                      <circle
                        cx="60"
                        cy="60"
                        r="45"
                        fill="none"
                        stroke="#F43F5E"
                        stroke-width="22"
                        stroke-dasharray="33.9 248.8"
