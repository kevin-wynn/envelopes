---
import TransactionsView from "../../components/TransactionsView";
import AppLayout from "../../layouts/AppLayout.astro";
import "../../styles/global.css";
---

<AppLayout title="Transactions" activeNav="transactions">
  <div class="p-6 lg:p-8">
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-ink-900">Transactions</h1>
      <p class="text-sm text-ink-500 mt-1">Track every dollar in and out</p>
    </div>
    <TransactionsView client:load />
  </div>
</AppLayout>
